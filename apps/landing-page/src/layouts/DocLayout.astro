            <span class="text-white/60" id="breadcrumb-current">{title}</span>
          </nav>
          <div class="flex items-center gap-2 text-[10px] font-mono text-white/20 uppercase tracking-tighter">
            <iconify-icon icon="solar:history-linear"></iconify-icon>
            <span>Last Updated: {new Date().toLocaleDateString('pt-BR')}</span>
          </div>
        </div>

        <!-- Language Notice Banner -->
        <div id="i18n-notice" class="hidden mb-8 p-4 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-amber-500/20 flex items-center justify-center text-amber-500">
              <iconify-icon icon="solar:global-bold" width="24"></iconify-icon>
            </div>
            <div>
              <p id="i18n-notice-text" class="text-sm font-medium text-amber-200/80 leading-tight">
                Este conteúdo está disponível apenas em Português.
              </p>
              <p class="text-[10px] text-amber-200/40 uppercase tracking-wider">Tradução automática em breve</p>
            </div>
          </div>
          <button onclick="document.getElementById('i18n-notice').remove()" class="text-amber-500/50 hover:text-amber-500 transition-colors">
            <iconify-icon icon="solar:close-circle-linear" width="20"></iconify-icon>
          </button>
        </div>

        <slot />
        
        <!-- Footer Actions -->
        <div class="mt-20 flex flex-col md:flex-row md:items-center justify-between gap-8 border-t border-white/5 pt-12">
          <div class="flex items-center gap-6">
            <span class="text-xs font-medium text-white/20 uppercase tracking-widest">Share</span>
            <div class="flex items-center gap-3">
              <button onclick="window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(document.title)}&url=${encodeURIComponent(window.location.href)}`, '_blank')" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:bg-white/5 transition-all">
                <iconify-icon icon="ri:twitter-x-fill" width="18"></iconify-icon>
              </button>
              <button onclick="window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(window.location.href)}`, '_blank')" class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:bg-white/5 transition-all">
                <iconify-icon icon="ri:linkedin-fill" width="18"></iconify-icon>
              </button>
            </div>
          </div>
          
          <div class="flex items-center gap-6">
            <span id="feedback-label" class="text-xs font-medium text-white/20 uppercase tracking-widest">Helpful?</span>
            <div class="flex items-center gap-2">
              <button onclick="handleFeedback('yes')" class="px-4 py-2 rounded-lg border border-white/10 text-xs font-bold hover:bg-emerald-500 hover:text-black transition-all">Yes</button>
              <button onclick="handleFeedback('no')" class="px-4 py-2 rounded-lg border border-white/10 text-xs font-bold hover:bg-red-500 hover:text-white transition-all">No</button>
            </div>
          </div>
        </div>
        </article>

        <div class="mt-20 grid grid-cols-2 gap-4 border-t border-white/5 pt-12">
          {prevLink ? (
            <a href={prevLink.href} class="group p-4 rounded-2xl bg-white/5 border border-white/5 hover:border-emerald-500/30 transition-all">
              <span class="text-[10px] uppercase tracking-widest text-white/30 font-bold block mb-1 next-prev-label" data-type="prev">Anterior</span>
              <span class="text-sm text-white/70 group-hover:text-white transition-colors">← {prevLink.label}</span>
            </a>
          ) : <div/>}
          
          {nextLink ? (
            <a href={nextLink.href} class="group p-4 rounded-2xl bg-white/5 border border-white/5 hover:border-emerald-500/30 transition-all text-right">
              <span class="text-[10px] uppercase tracking-widest text-white/30 font-bold block mb-1 next-prev-label" data-type="next">Próximo</span>
              <span class="text-sm text-white/70 group-hover:text-white transition-colors">{nextLink.label} →</span>
            </a>
          ) : <div/>}
        </div>

        <footer class="mt-20 pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-xs text-white/20">Stellar Global Rails &copy; 2026 — Documentação Interna</p>
          <div class="flex items-center gap-6">
            <span class="text-[10px] text-white/20 uppercase tracking-widest font-bold" id="footer-update-label">Atualizado: 09 Maio, 2026</span>
          </div>
        </footer>
      </div>
    </main>

    <script is:inline src="/i18n-engine.js"></script>
    <script is:inline>
      function initDocs() {
        if (window.i18n) window.i18n.updateUI();
        
        const article = document.querySelector('article');
        const readingTimeEl = document.getElementById('reading-time');
        if (article && readingTimeEl) {
          const text = article.innerText || article.textContent;
          const words = text.trim().split(/\s+/).length;
          const minutes = Math.max(1, Math.ceil(words / 200));
          const lang = localStorage.getItem('sgr-lang') || 'en';
          const labels = { 'pt-br': 'min de leitura', 'en': 'min read', 'es': 'min de lectura', 'zh': '分钟阅读', 'ko': '분 소요', 'ar': 'دقائق للقراءة' };
          readingTimeEl.innerHTML = `<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-width="2"/></svg> ${minutes} ${labels[lang] || labels['en']}`;
        }

        const selector = document.getElementById('doc-lang-selector');
        if (selector) {
          selector.value = localStorage.getItem('sgr-lang') || 'en';
          selector.onchange = (e) => {
            const lang = e.target.value;
            localStorage.setItem('sgr-lang', lang);
            window.dispatchEvent(new CustomEvent('sgr-lang-changed', { detail: lang }));
            document.documentElement.lang = lang;
            document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
            if (window.i18n) window.i18n.updateUI();
          };
        }

        window.addEventListener('sgr-lang-changed', () => {
           if (window.i18n) window.i18n.updateUI();
        });

        // Mermaid
        if (window.mermaid) {
          mermaid.initialize({ startOnLoad: false, theme: 'dark', securityLevel: 'loose', fontFamily: 'Inter' });
          mermaid.run({ querySelector: '.mermaid' });
        }

        // Copy Buttons
        document.querySelectorAll('pre').forEach(block => {
          if (block.classList.contains('mermaid')) return;
          if (!block.querySelector('.copy-button')) {
            const button = document.createElement('button');
            button.className = 'copy-button';
            button.innerHTML = '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" stroke-width="2"/></svg>';
            button.onclick = () => {
              const text = block.querySelector('code').innerText;
              navigator.clipboard.writeText(text);
              button.innerHTML = '<svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M5 13l4 4L19 7" stroke-width="3"/></svg>';
              setTimeout(() => { button.innerHTML = '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" stroke-width="2"/></svg>'; }, 2000);
            };
            block.appendChild(button);
          }
        });

        // TOC Generation
        const tocNav = document.getElementById('toc-nav');
        if (tocNav && article) {
          tocNav.innerHTML = '';
          article.querySelectorAll('h2, h3').forEach((heading, i) => {
            if (!heading.id) heading.id = `heading-${i}`;
            const link = document.createElement('a');
            link.href = `#${heading.id}`;
            link.className = `toc-link block px-3 py-1.5 rounded-lg text-xs transition-all ${heading.tagName === 'H3' ? 'ml-4 text-white/30' : 'text-white/50 font-medium'} hover:text-white hover:bg-white/5`;
            link.innerText = heading.innerText;
            tocNav.appendChild(link);
          });
        }
      }

      initDocs();
      document.addEventListener('astro:page-load', initDocs);
    </script>
    <script is:inline>
      // Product tab switching
      function initProductTabs() {
        const tabs = document.querySelectorAll('[data-product-tab]');
        const navs = document.querySelectorAll('[data-product-nav]');

        tabs.forEach(function(tab) {
          tab.addEventListener('click', function() {
            var product = tab.getAttribute('data-product-tab');

            // Update tab styles
            tabs.forEach(function(t) {
              t.classList.remove('bg-emerald-500/20', 'text-emerald-400', 'shadow-sm');
              t.classList.add('text-white/30');
            });
            tab.classList.add('bg-emerald-500/20', 'text-emerald-400', 'shadow-sm');
            tab.classList.remove('text-white/30');

            // Show/hide nav sections
            navs.forEach(function(nav) {
              if (nav.getAttribute('data-product-nav') === product) {
                nav.classList.remove('hidden');
                nav.classList.add('block');
              } else {
                nav.classList.add('hidden');
                nav.classList.remove('block');
              }
            });
          });
        });
      }

      initProductTabs();
      document.addEventListener('astro:page-load', initProductTabs);
    </script>
    <script is:inline>
      // Reading Progress Bar logic
      window.addEventListener('scroll', () => {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        document.getElementById("progress-bar").style.width = scrolled + "%";
      });

      // Breadcrumb Dynamic Label (from sidebar if available)
      document.addEventListener('DOMContentLoaded', () => {
        const currentPath = window.location.pathname;
        const activeLink = document.querySelector(`a[href="${currentPath}"]`);
        if (activeLink) {
          const text = activeLink.innerText.trim();
          const bcLabel = document.getElementById('breadcrumb-current');
          if (bcLabel) bcLabel.innerText = text;
        }
      });

      // Copy to Clipboard logic
      // Copy to Clipboard logic
      function initCopyButtons() {
        const blocks = document.querySelectorAll('pre');
        blocks.forEach((block) => {
          if (block.querySelector('.copy-code-btn')) return;
          
          const isSql = block.classList.contains('language-sql') || block.querySelector('code.language-sql');
          
          const button = document.createElement('button');
          button.className = 'copy-code-btn flex items-center gap-2';
          button.innerHTML = `<iconify-icon icon="solar:copy-linear"></iconify-icon> ${isSql ? '<span class="text-[10px] font-bold">SQL</span>' : ''}`;
          
          button.addEventListener('click', async () => {
            const code = block.querySelector('code');
            const text = code ? code.innerText : block.innerText;
            
            await navigator.clipboard.writeText(text);
            
            button.innerHTML = '<iconify-icon icon="solar:check-read-linear"></iconify-icon>';
            button.classList.add('text-emerald-400');
            
            setTimeout(() => {
              button.innerHTML = `<iconify-icon icon="solar:copy-linear"></iconify-icon> ${isSql ? '<span class="text-[10px] font-bold">SQL</span>' : ''}`;
              button.classList.remove('text-emerald-400');
            }, 2000);
          });
          
          block.appendChild(button);
        });
      }

      function checkLanguageNotice() {
        const lang = localStorage.getItem('sgr-lang') || 'pt-br';
        const notice = document.getElementById('i18n-notice');
        if (notice && lang !== 'pt-br') {
          notice.classList.remove('hidden');
          const noticeText = document.getElementById('i18n-notice-text');
          if (noticeText && window.i18nEngine) {
            noticeText.innerText = window.i18nEngine.translate('doc.translate_notice');
          }
        }
      }

      function handleFeedback(type) {
        const label = document.getElementById('feedback-label');
        if (label) {
          label.innerText = type === 'yes' ? 'Thanks! ❤️' : 'Thanks for letting us know!';
          label.classList.add('text-emerald-400');
        }
        // In a real app, send to Supabase here
        console.log('Feedback:', type, window.location.pathname);
      }

      function initGlossary() {
        const glossary = {
          'SEP-24': 'Protocolo Stellar para depósitos e saques com integração de KYC.',
          'Ledger': 'A blockchain pública da Stellar onde as transações são registradas.',
          'RLS': 'Row Level Security - segurança a nível de linha no PostgreSQL.',
          'On-chain': 'Registrado diretamente na blockchain.',
          'Asset': 'Representação digital de um valor ou direito na rede.',
          'Soroban': 'A plataforma de Smart Contracts da rede Stellar.',
          'Anchor': 'Entidade que conecta a rede Stellar ao sistema bancário tradicional.'
        };

        const article = document.querySelector('article');
        if (!article) return;

        const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT, null, false);
        const nodes = [];
        let node;
        while(node = walker.nextNode()) {
          if (node.parentElement.tagName !== 'SCRIPT' && node.parentElement.tagName !== 'STYLE' && node.parentElement.tagName !== 'CODE' && node.parentElement.tagName !== 'PRE') {
            nodes.push(node);
          }
        }

        nodes.forEach(textNode => {
          let text = textNode.nodeValue;
          let changed = false;
          
          Object.keys(glossary).forEach(term => {
            const regex = new RegExp(`\\b${term}\\b`, 'g');
            if (regex.test(text)) {
              changed = true;
              text = text.replace(regex, `<span class="glossary-term">${term}<span class="glossary-tooltip">${glossary[term]}</span></span>`);
            }
          });

          if (changed) {
            const span = document.createElement('span');
            span.innerHTML = text;
            textNode.parentNode.replaceChild(span, textNode);
          }
        });
      }

      document.addEventListener('DOMContentLoaded', () => {
        initCopyButtons();
        checkLanguageNotice();
        initGlossary();
      });
      document.addEventListener('astro:page-load', () => {
        initCopyButtons();
        checkLanguageNotice();
        initGlossary();
      });

      // Mobile Menu Toggle
      const mobileToggle = document.getElementById('mobile-menu-toggle');
      const sidebar = document.getElementById('doc-sidebar');
      
      if (mobileToggle && sidebar) {
        mobileToggle.addEventListener('click', () => {
          sidebar.classList.toggle('-translate-x-full');
        });
      }

      // Search Logic
      const searchInput = document.getElementById('doc-search');
      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          const query = e.target.value.toLowerCase();
          const links = document.querySelectorAll('.nav-link');
          const sections = document.querySelectorAll('.doc-section');
          
          links.forEach(link => {
            const text = link.innerText.toLowerCase();
            if (text.includes(query)) {
              link.parentElement.style.display = 'block';
            } else {
              link.parentElement.style.display = 'none';
            }
          });

          // Hide sections with no visible links
          sections.forEach(section => {
            const visibleLinks = section.querySelectorAll('li[style="display: block;"], li:not([style])');
            section.style.display = visibleLinks.length > 0 ? 'block' : 'none';
          });
        });
      }

      // Smooth Scroll and TOC
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    </script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
    <script is:inline>
      mermaid.initialize({ 
        startOnLoad: true, 
        theme: 'dark',
        themeVariables: {
          primaryColor: '#10b981',
          primaryTextColor: '#fff',
          primaryBorderColor: '#10b981',
          lineColor: '#34d399',
          secondaryColor: '#064e3b',
          tertiaryColor: '#0a0a0a'
        }
      });
    </script>
  </body>
