        </div>

        <div id="i18n-notice" class="hidden mb-8 p-4 rounded-xl bg-emerald-500/10 border border-emerald-500/20 backdrop-blur-sm">
          <div class="flex items-start gap-3">
            {/* @ts-ignore */}
            <iconify-icon icon="solar:translation-bold-duotone" class="text-emerald-400 mt-0.5" width="20"></iconify-icon>
