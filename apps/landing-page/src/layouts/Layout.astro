---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import Navigation from '../components/Navigation';
import Footer from '../components/Footer';
import Atmosphere from '../components/Atmosphere';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    {/* Item 40: Dynamic Meta Images */}
    <meta name="description" content="Infraestrutura global de pagamentos baseada na rede Stellar." />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Infraestrutura global de pagamentos baseada na rede Stellar." />
    <meta property="og:image" content="https://kivo.com/api/og?metrics=true" />
    <meta property="og:type" content="website" />
    
    {/* Item 35: Suporte PWA */}
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#10B981" />

    {/* Item 41: Web Monetization Experimental */}
    <meta name="monetization" content="$ilp.uphold.com/kivopayments" />

    <title>{title}</title>
    <ViewTransitions />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* 43. Fonte Bricolage Otimizada (Preload para evitar FOIT) */}
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:wght@400;500;600&display=swap&subset=latin,latin-ext" />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:wght@400;500;600&display=swap&subset=latin,latin-ext" rel="stylesheet" />
    <script src="https://code.iconify.design/3/3.1.0/iconify.min.js"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
  </head>
  <body>
    <div class="bg-[#050505] min-h-screen font-sans selection:bg-emerald-500 selection:text-black overflow-x-clip">
      <Atmosphere client:load />
      <div class="bg-grain"></div>
      
      {/* Item 34: Zero-JS Fallback UX */}
      <noscript>
        <div class="bg-red-500/10 border-b border-red-500/20 text-white text-center p-4">
          <p class="font-bricolage text-red-400"><strong>Modo de Alta Segurança (Zero-JS) ativo.</strong> O site continua legível, mas simuladores interativos requerem JavaScript.</p>
        </div>
      </noscript>

      <Navigation client:load />
      <main>
        <slot />
      </main>
      <Footer client:load />
    </div>

    {/* Item 35: Registrar Service Worker (PWA) */}
    <script is:inline>
      // Language Detection & Persistence
      (function() {
        const LANG_KEYS = ['pt-br', 'en', 'es', 'zh', 'ko', 'ar'];
        const saved = localStorage.getItem('sgr-lang');
        let lang = 'en';

        if (saved && LANG_KEYS.includes(saved)) {
          lang = saved;
        } else {
          const browserLang = navigator.language.toLowerCase();
          const matched = LANG_KEYS.find(k => browserLang.startsWith(k));
          if (matched) lang = matched;
          localStorage.setItem('sgr-lang', lang);
        }
        
        // Update title and description from UI dictionary
        // We pass the essential metadata to the client
        const meta = {
          'pt-br': { title: 'Stellar Global Rails | Infraestrutura Financeira Global', desc: 'Construindo o futuro das finanças globais sobre a rede Stellar.' },
          'en': { title: 'Stellar Global Rails | Global Financial Infrastructure', desc: 'Building the future of global finance on the Stellar network.' },
          'es': { title: 'Stellar Global Rails | Infraestructura Financiera Global', desc: 'Construyendo el futuro de las finanzas globales sobre la red Stellar.' },
          'zh': { title: 'Stellar Global Rails | 全球金融基础设施', desc: '在 Stellar 网络上构建全球金融的未来。' },
          'ko': { title: 'Stellar Global Rails | 글로벌 금융 인프라', desc: 'Stellar 네트워크를 기반으로 글로벌 금융의 미래를 구축합니다.' },
          'ar': { title: 'Stellar Global Rails | البنية التحتية المالية العالمية', desc: 'بناء مستقبل التمويل العالمي على شبكة Stellar.' }
        };

        const updateMetadata = (l) => {
          const m = meta[l] || meta['en'];
          document.title = m.title;
          const metaDesc = document.querySelector('meta[name="description"]');
          if (metaDesc) metaDesc.setAttribute('content', m.desc);
          const ogDesc = document.querySelector('meta[property="og:description"]');
          if (ogDesc) ogDesc.setAttribute('content', m.desc);
          
          // Update HTML lang and dir
          document.documentElement.lang = l;
          document.documentElement.dir = l === 'ar' ? 'rtl' : 'ltr';
        };

        updateMetadata(lang);

        window.addEventListener('sgr-lang-changed', (e) => {
          updateMetadata(e.detail);
        });
      })();

      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>

    <script>
      document.addEventListener('astro:page-load', () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                const delay = parseFloat((entry.target as HTMLElement).dataset.delay || '0');
                if (delay > 0) {
                  (entry.target as HTMLElement).style.transitionDelay = `${delay}s`;
                }
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
        );

        const elements = document.querySelectorAll('.gs-fade-up, .gs-slide-left, .gs-slide-right');
        elements.forEach((el) => observer.observe(el));
      });
    </script>
  </body>
</html>