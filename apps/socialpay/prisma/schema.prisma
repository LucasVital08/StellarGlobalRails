generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                    String        @id @default(cuid())
  name                  String
  email                 String        @unique
  passwordHash          String?
  handle                String        @unique
  accountType           String        @default("person")
  profileVisibility     String        @default("public")
  etherfuseCustomerId   String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  wallet                Wallet?
  sentTransactions      Transaction[] @relation("SentTransactions")
  receivedTransactions  Transaction[] @relation("ReceivedTransactions")
  ownedOrganizations    Organization[] @relation("OrgOwner")
  rampOrders            RampOrder[]
}

model Wallet {
  id              String   @id @default(cuid())
  userId          String   @unique
  publicKey       String   @unique
  encryptedSecret String
  network         String   @default("testnet")
  funded          Boolean  @default(false)
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                String    @id @default(cuid())
  senderUserId      String
  receiverUserId    String
  senderHandle      String
  receiverHandle    String
  senderPublicKey   String
  receiverPublicKey String
  amount            String
  assetCode         String    @default("XLM")
  assetIssuer       String?
  description       String?
  visibility        String    @default("public")
  status            String    @default("draft")
  stellarHash       String?
  explorerUrl       String?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  submittedAt       DateTime?
  confirmedAt       DateTime?

  sender            User      @relation("SentTransactions", fields: [senderUserId], references: [id])
  receiver          User      @relation("ReceivedTransactions", fields: [receiverUserId], references: [id])
}

model Organization {
  id          String    @id @default(cuid())
  name        String
  handle      String    @unique
  ownerUserId String
  createdAt   DateTime  @default(now())

  owner       User      @relation("OrgOwner", fields: [ownerUserId], references: [id])
  projects    Project[]
}

model Project {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  handle         String       @unique
  description    String?
  budgetAmount   String?
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])
}

// Rastreia ordens de on-ramp (BRL→USDC) e off-ramp (USDC→BRL) via Etherfuse
model RampOrder {
  id                  String    @id @default(cuid())
  userId              String
  type                String    // "onramp" | "offramp"
  status              String    @default("pending")
  // Etherfuse IDs
  etherfuseOrderId    String?   @unique
  etherfuseQuoteId    String?
  // Valores
  fiatAmount          String
  fiatCurrency        String    @default("BRL")
  cryptoAmount        String?
  cryptoAssetCode     String    // "TESOURO" | "USDC"
  cryptoAssetIssuer   String
  // Stellar
  walletPublicKey     String
  // On-ramp: instrução Pix
  pixKey              String?
  pixQrCode           String?
  pixExpiration       DateTime?
  // Off-ramp: memo OBRIGATÓRIO (sem memo = ordem órfã)
  memo                String?
  destinationAddress  String?
  bankAccountId       String?
  stellarHash         String?
  errorMessage        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                User      @relation(fields: [userId], references: [id])
}
